# Copy this file to .env and fill in your actual API keys. Never commit .env to git.

# Process 1 (Vision scan) + Process 2 (Analysis) — Groq free tier
# Sign up at console.groq.com → API Keys — 500 vision calls/day, 14,400 text calls/day free
GROQ_API_KEY=your_groq_api_key_here

# Fallback only — Gemini (gemini-2.5-flash-lite, 20 req/day free)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional — HuggingFace (dead code, not used)
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Optional — OCR.Space (barcode/label OCR fallback)
OCR_API_KEY=your_ocr_space_api_key_here

# Optional — USDA FoodData Central (nutrition composition fallback)
USDA_API_KEY=your_usda_fdc_api_key_here

# Optional
NODE_ENV=development
PORT=10000
